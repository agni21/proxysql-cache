# ProxySQL Cache Configuration
# Copy this file to .env and fill in the values

# --- Mode A: Remote MySQL (e.g. RDS) ---
# MYSQL_HOST=your-rds-hostname.region.rds.amazonaws.com

# --- Mode B: Local MySQL Docker service (bootstrapped from a dump) ---
# start.sh will spin up a mysql:8.0 container and import the dump automatically.
# MYSQL_HOST=mysql
# DUMP_PATH=/path/to/your/dump.gz

# --- Mode C: Externally managed local MySQL (already running, no Docker service) ---
# Use host.docker.internal so ProxySQL container can reach your host machine's MySQL.
# MYSQL_HOST=host.docker.internal

MYSQL_HOST=your-rds-hostname.region.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_DATABASE=your_database
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password

# Local MySQL dump path (only required for Mode B)
# DUMP_PATH=/path/to/your/dump.gz

# ProxySQL Admin
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin

# Cache settings
CACHE_TTL_MS=300000
CACHE_SIZE_MB=256
