# ProxySQL Cache Configuration
# Copy this file to .env and fill in the values

# --- Option A: Remote MySQL (e.g. RDS) ---
# MYSQL_HOST=your-rds-hostname.region.rds.amazonaws.com

# --- Option B: Local MySQL Docker service ---
# Set MYSQL_HOST=mysql and provide a DUMP_PATH to bootstrap from a dump.
# MYSQL_HOST=mysql
# DUMP_PATH=/path/to/your/dump.gz

MYSQL_HOST=your-rds-hostname.region.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_DATABASE=your_database
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password

# Local MySQL dump path (only required when MYSQL_HOST=mysql)
# DUMP_PATH=/path/to/your/dump.gz

# ProxySQL Admin
PROXYSQL_ADMIN_USER=admin
PROXYSQL_ADMIN_PASSWORD=admin

# Cache settings
CACHE_TTL_MS=300000
CACHE_SIZE_MB=256
